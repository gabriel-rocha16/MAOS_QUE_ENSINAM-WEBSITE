<nav data-controller="navbar" 
     data-action="scroll@window->navbar#update" 
     data-navbar-target="container"
     class="fixed top-0 left-0 z-50 w-full transition-all duration-300 bg-transparent">
  <div class="max-w-7xl mx-auto px-5 md:px-6">
    <div class="flex items-center justify-between h-20">

<div class="flex items-center gap-2">
        <%= link_to root_path, class: "block transition-transform hover:scale-105" do %>
          <%= image_tag "logo.png", class: "h-12 md:h-14 w-auto object-contain" %>
        <% end %>
      </div>

      <div class="hidden md:flex items-center gap-10 font-medium">
        <%= link_to "Início", root_path, data: { navbar_target: "link" }, class: "text-white hover:text-yellow-400 transition-colors duration-300" %>
        <%= link_to "Cursos", cursos_path, data: { navbar_target: "link" }, class: "text-white hover:text-yellow-400 transition-colors duration-300" %>
        <%= link_to "Sobre", about_path, data: { navbar_target: "link" }, class: "text-white hover:text-yellow-400 transition-colors duration-300" %>
        <%= link_to "Contato", contact_path, data: { navbar_target: "link" }, class: "text-white hover:text-yellow-400 transition-colors duration-300" %>
      </div>

      <div class="flex items-center gap-4">
        <% if usuario_signed_in? %>
          <span data-navbar-target="greeting" class="text-white hidden md:inline-block font-medium mr-2 transition-colors duration-300">Olá, <%= current_usuario.email.split('@').first %></span>
          
          <% if current_usuario.gestor&.present? %>
            <%= link_to "Painel", admin_dashboard_path, data: { navbar_target: "loginBtn" }, class: "px-6 py-2 rounded-full border border-white text-white hover:bg-blue-50 hover:text-blue-600 transition-colors duration-300 text-sm md:text-base font-medium" %>
          <% elsif current_usuario.candidato&.present? %>
            <%= link_to "Meu Perfil", candidato_path, data: { navbar_target: "loginBtn" }, class: "px-6 py-2 rounded-full border border-white text-white hover:bg-blue-50 hover:text-blue-600 transition-colors duration-300 text-sm md:text-base font-medium" %>
          <% end %>

          <%= link_to "Sair", destroy_usuario_session_path, data: { turbo_method: :delete }, class: "hidden md:inline-flex px-6 py-2 rounded-full bg-red-500 text-white font-semibold hover:bg-red-600 transition duration-300" %>
        <% else %>
          <%= link_to "Entrar", login_path,
            data: { navbar_target: "loginBtn" },
            class: "px-6 py-2 rounded-full border border-white text-white hover:bg-blue-50 hover:text-blue-600 transition-colors duration-300 text-sm md:text-base font-medium" %>

          <%= link_to "Começar Agora", signup_path,
            class: "hidden md:inline-flex px-6 py-2 rounded-full bg-yellow-400 text-blue-900 font-semibold hover:bg-yellow-500 transition duration-300" %>
        <% end %>
      </div>

    </div>
  </div>
</nav>