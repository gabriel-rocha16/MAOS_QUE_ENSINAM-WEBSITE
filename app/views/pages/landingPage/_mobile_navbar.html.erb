<div class="fixed bottom-0 left-0 w-full border-t z-50 transition-all duration-300 bg-white/80 backdrop-blur-md md:hidden">
  <div class="flex justify-around items-center h-16">

    <!-- Início -->
    <%= link_to root_path, class: "flex flex-col items-center nav-link-mobile" do %>
      <i data-lucide="house" class="w-6 h-6"></i>
      <span class="text-xs">Início</span>
    <% end %>

    <!-- Cursos -->
    <%= link_to cursos_path, class: "flex flex-col items-center nav-link-mobile" do %>
      <i data-lucide="graduation-cap" class="w-6 h-6"></i>
      <span class="text-xs">Cursos</span>
    <% end %>

    <!-- Sobre -->
    <%= link_to about_path, class: "flex flex-col items-center nav-link-mobile" do %>
      <i data-lucide="user" class="w-6 h-6"></i>
      <span class="text-xs">Sobre</span>
    <% end %>

    <!-- Contato -->
    <%= link_to contact_path, class: "flex flex-col items-center nav-link-mobile" do %>
      <i data-lucide="phone" class="w-6 h-6"></i>
      <span class="text-xs">Contato</span>
    <% end %>

  </div>
</div>