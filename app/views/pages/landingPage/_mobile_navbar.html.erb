<div class="fixed bottom-0 left-0 w-full border-t border-gray-200 z-50 bg-white md:hidden">
  <div class="flex justify-around items-center h-16 px-2">

<% inicio_ativo = current_page?(root_path) %>
    <%= link_to root_path, class: "flex flex-col items-center gap-1 w-16" do %>
      <div class="flex items-center justify-center w-10 h-10 rounded-full <%= inicio_ativo ? 'bg-blue-50 text-blue-600' : 'text-gray-500 hover:bg-gray-50' %> transition-colors">
        <i data-lucide="home" class="w-5 h-5"></i>
      </div>
      <span class="text-[11px] font-medium <%= inicio_ativo ? 'text-blue-600' : 'text-gray-500' %>">Início</span>
    <% end %>

    <% cursos_ativo = current_page?(cursos_path) %>
    <%= link_to cursos_path, class: "flex flex-col items-center gap-1 w-16" do %>
      <div class="flex items-center justify-center w-10 h-10 rounded-full <%= cursos_ativo ? 'bg-blue-50 text-blue-600' : 'text-gray-500 hover:bg-gray-50' %> transition-colors">
        <i data-lucide="graduation-cap" class="w-5 h-5"></i>
      </div>
      <span class="text-[11px] font-medium <%= cursos_ativo ? 'text-blue-600' : 'text-gray-500' %>">Cursos</span>
    <% end %>

    <% sobre_ativo = current_page?(about_path) %>
    <%= link_to about_path, class: "flex flex-col items-center gap-1 w-16" do %>
      <div class="flex items-center justify-center w-10 h-10 rounded-full <%= sobre_ativo ? 'bg-blue-50 text-blue-600' : 'text-gray-500 hover:bg-gray-50' %> transition-colors">
        <i data-lucide="book-open" class="w-5 h-5"></i>
      </div>
      <span class="text-[11px] font-medium <%= sobre_ativo ? 'text-blue-600' : 'text-gray-500' %>">Sobre</span>
    <% end %>

    <% contato_ativo = current_page?(contact_path) %>
    <%= link_to contact_path, class: "flex flex-col items-center gap-1 w-16" do %>
      <div class="flex items-center justify-center w-10 h-10 rounded-full <%= contato_ativo ? 'bg-blue-50 text-blue-600' : 'text-gray-500 hover:bg-gray-50' %> transition-colors">
        <i data-lucide="phone" class="w-5 h-5"></i>
      </div>
      <span class="text-[11px] font-medium <%= contato_ativo ? 'text-blue-600' : 'text-gray-500' %>">Contato</span>
    <% end %>

  </div>
</div>