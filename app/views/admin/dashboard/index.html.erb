<div class="max-w-7xl mx-auto mt-10 px-4 pb-10">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-gray-800">Oficina de Cursos</h1>
    <% if current_usuario.gestor.present? || current_usuario.instrutor.present? %>
      <%= link_to "+ Novo Curso", new_curso_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-full shadow-md transition-colors" %>
    <% end %>
  </div>

  <div class="bg-white rounded-lg shadow-md overflow-hidden border border-gray-100">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Curso</th>
          <% if current_usuario.gestor.present? %>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Autor</th>
          <% end %>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Ações</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @cursos.each do |curso| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex items-center">
                <div>
                  <div class="text-sm font-medium text-gray-900"><%= curso.nome %></div>
                  <div class="text-sm text-gray-500"><%= curso.area %></div>
                </div>
              </div>
            </td>
            <% if current_usuario.gestor.present? %>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900"><%= curso.usuario&.nome || "Sistema" %></div>
              </td>
            <% end %>
            <td class="px-6 py-4 whitespace-nowrap">
              <% if curso.rascunho? %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">Rascunho</span>
              <% elsif curso.aguardando_aprovacao? %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">Em Revisão</span>
              <% else %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Publicado</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <%= link_to "Editar", edit_curso_path(curso), class: "text-blue-600 hover:text-blue-900 mr-3" %>
              <%= link_to "Ver", curso_path(curso), class: "text-gray-600 hover:text-gray-900" %>
            </td>
          </tr>
        <% end %>
        
        <% if @cursos.empty? %>
          <tr>
            <td colspan="<%= current_usuario.gestor.present? ? 4 : 3 %>" class="px-6 py-10 text-center text-gray-500">
              <svg class="mx-auto h-12 w-12 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
              Nenhum curso encontrado.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
