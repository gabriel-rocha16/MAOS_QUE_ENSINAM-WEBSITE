<h1>Área do Aluno</h1>

<h2>Meus Cursos</h2>
<ul>
  <% if current_usuario.candidato.cursos.any? %>
    <% current_usuario.candidato.cursos.each do |curso| %>
      <li><%= curso.nome %> - <%= link_to "Ver Detalhes", curso_path(curso) %></li>
    <% end %>
  <% else %>
    <p>Você ainda não está matriculado em nenhum curso.</p>
  <% end %>
</ul>

<h2>Cursos Disponíveis</h2>
<ul>
  <% Curso.publicado.each do |curso| %>
    <li><%= curso.nome %> - <%= link_to "Ver Detalhes", curso_path(curso) %></li>
  <% end %>
</ul>
