<div class="max-w-2xl mx-auto mt-10">
  <h2 class="text-2xl font-bold mb-6">Completar Perfil de Aluno</h2>

  <%= form_with model: @candidato, local: true, html: { class: "bg-white shadow-md rounded px-8 pt-6 pb-8 mb-4" } do |f| %>
    <% if @candidato.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4">
        <ul>
          <% @candidato.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-2 gap-4 mb-4">
      <div>
        <%= f.label :cidade, "Cidade", class: "block text-gray-700 text-sm font-bold mb-2" %>
        <%= f.text_field :cidade, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
      </div>
      <div>
        <%= f.label :estado, "Estado", class: "block text-gray-700 text-sm font-bold mb-2" %>
        <%= f.text_field :estado, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
      </div>
    </div>

    <div class="mb-4">
      <%= f.label :data_nascimento, "Data de Nascimento", class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= f.date_field :data_nascimento, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
    </div>

    <div class="mb-4">
      <%= f.label :escolaridade, "Escolaridade", class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= f.select :escolaridade, ["Ensino Fundamental Incompleto", "Ensino Fundamental Completo", "Ensino Médio Incompleto", "Ensino Médio Completo", "Ensino Superior Incompleto", "Ensino Superior Completo"], { include_blank: "Selecione..." }, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
    </div>

    <div class="mb-4">
      <label class="flex items-center">
        <%= f.check_box :trabalhando, class: "mr-2 leading-tight" %>
        <span class="text-gray-700 text-sm font-bold">Está trabalhando atualmente?</span>
      </label>
    </div>

    <div class="mb-4">
      <label class="flex items-center">
        <%= f.check_box :possui_beneficio, class: "mr-2 leading-tight" %>
        <span class="text-gray-700 text-sm font-bold">Recebe algum benefício do governo?</span>
      </label>
    </div>

    <div class="mb-6">
      <label class="flex items-center">
        <%= f.check_box :possui_deficiencia, class: "mr-2 leading-tight" %>
        <span class="text-gray-700 text-sm font-bold">Possui alguma deficiência?</span>
      </label>
    </div>

    <div class="mb-4">
      <%= f.label :laudos_medicos, "Documentos Comprobatórios (Laudo, Exames, etc)", class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= f.file_field :laudos_medicos, multiple: true, direct_upload: true, class: "mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" %>
      <p class="text-xs text-gray-500 mt-1">Aceitamos PDF, PNG e JPG (Máx 5MB por arquivo. Selecione de 1 a 3 arquivos).</p>
    </div>

    <div class="flex items-center justify-between">
      <%= f.submit "Finalizar Cadastro de Perfil", class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline cursor-pointer" %>
    </div>
  <% end %>
</div>
