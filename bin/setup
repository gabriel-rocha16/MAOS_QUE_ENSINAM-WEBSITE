require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

FileUtils.chdir APP_ROOT do
  puts "== Installing dependencies =="
  system("bundle check") || system!("bundle install")

  puts "\n== Preparing environment files =="
  unless File.exist?(".env")
    if File.exist?(".env.example")
      puts "Copying .env.example to .env..."
      FileUtils.cp ".env.example", ".env"
    else
      puts "Creating default .env file..."
      File.write(".env", "DB_USER=postgres\nDB_PASSWORD=\nDB_HOST=localhost")
    end
    puts "!!! Arquivo .env criado. Se o banco falhar, edite-o com sua senha. !!!"
  end

  puts "\n== Preparing database =="
  begin
    system! "bin/rails db:prepare"
  rescue RuntimeError
    puts "\n[ERRO DE CONEXÃO]"
    puts "Não consegui conectar ao seu banco de dados."
    puts "Por favor, verifique se o serviço do PostgreSQL está rodando e se"
    puts "o seu usuário/senha no arquivo .env estão corretos."
    exit 1
  end

  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  unless ARGV.include?("--skip-server")
    puts "\n== Starting development server =="
    STDOUT.flush
    exec "bin/dev"
  end
end