<div class="max-w-2xl mx-auto mt-10">
  <h2 class="text-2xl font-bold mb-6 text-gray-800">Completar Perfil de Instrutor</h2>

  <%= form_with model: @instrutor, local: true, html: { class: "bg-white shadow-md rounded px-8 pt-6 pb-8 mb-4" } do |f| %>
    <% if @instrutor.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4">
        <ul>
          <% @instrutor.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-4">
      <%= f.label :formacao_academica, "Formação Acadêmica", class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= f.text_field :formacao_academica, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
    </div>

    <div class="mb-4">
      <%= f.label :capacitacao, "Capacitação / Certificações", class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= f.text_area :capacitacao, rows: 3, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
    </div>

    <div class="mb-6">
      <%= f.label :bio, "Bio / Resumo Profissional", class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= f.text_area :bio, rows: 5, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
    </div>

    <div class="flex items-center justify-between">
      <%= f.submit "Finalizar Cadastro de Instrutor", class: "bg-green-500 hover:bg-green-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline cursor-pointer" %>
    </div>
  <% end %>
</div>
